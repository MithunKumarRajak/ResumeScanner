# Global ignores
.DS_Store
Thumbs.db
*.log

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/

# Node
node_modules/
dist/
build/

# Include project documentation and the Resume Editor app in version control
