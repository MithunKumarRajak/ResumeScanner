# ── App ───────────────────────────────────────────────────
APP_NAME="Resume Screener API"
APP_VERSION="2.0.0"
DEBUG=true

# ── Database ──────────────────────────────────────────────
# PostgreSQL (default — production-ready):
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/resume_screener

# SQLite (fallback — uncomment for quick local dev):
# DATABASE_URL=sqlite:///./resume_screener.db

# ── JWT Auth ──────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
SECRET_KEY=change-this-secret-key-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── File Upload ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ── ML Model Paths (relative to backend/ working dir) ─────
MODEL_PATH=../model.pkl
TFIDF_PATH=../tfidf.pkl
ENCODER_PATH=../encoder.pkl
